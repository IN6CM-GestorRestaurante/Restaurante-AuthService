    {
      "name": "2. Login (SUPER_ADMIN)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const json = pm.response.json();",
              "    pm.environment.set('jwt_token', json.accessToken || '');",
              "    pm.environment.set('refresh_token', json.refreshToken || '');",
              "    if (json.userDetails) {",
              "        pm.environment.set('AUTH_USER_ID', json.userDetails.id);",
              "        pm.environment.set('AUTH_USER_ROLE', json.userDetails.role);",
              "        if (json.userDetails.mongoId) pm.environment.set('ID_MONGO_USER', json.userDetails.mongoId);",
              "    }",
              "    pm.test('Login exitoso', () => pm.expect(json.success).to.be.true);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
